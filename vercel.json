{
  "rewrites": [
    {
      "source": "/x-api/:path*",
      "destination": "https://cdn.syndication.twimg.com/:path*"
    },
    {
      "source": "/x-video/:path*",
      "destination": "https://video.twimg.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}
